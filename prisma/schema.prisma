generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  level     String?  // A1, A2, B1, B2, C1, C2
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("students")
}

model TimeSlot {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=domingo, 1=lunes... 6=sábado
  startTime String   // "09:00"
  endTime   String   // "09:55"
  available Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings Booking[]

  @@unique([dayOfWeek, startTime])
  @@map("time_slots")
}

model Booking {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  timeSlotId    String
  timeSlot      TimeSlot      @relation(fields: [timeSlotId], references: [id])
  level         String        // A1-C2
  sessionsTotal Int           @default(4)
  sessionsUsed  Int           @default(0)
  status        BookingStatus @default(PENDING_PAYMENT)
  startDate     DateTime?     // primera clase
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payment  Payment?
  sessions ClassSession[]

  @@map("bookings")
}

enum BookingStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  CANCELLED
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  amountCents       Int
  currency          String        @default("eur")
  stripeSessionId   String?       @unique
  stripePaymentId   String?
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model ClassSession {
  id         String             @id @default(cuid())
  bookingId  String
  booking    Booking            @relation(fields: [bookingId], references: [id])
  date       DateTime
  startTime  String             // "09:00"
  endTime    String             // "09:55"
  status     ClassSessionStatus @default(SCHEDULED)
  zoomLink   String?
  cancelledAt DateTime?
  createdAt  DateTime           @default(now())

  @@map("class_sessions")
}

enum ClassSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED_ON_TIME    // anulada con >48h
  CANCELLED_LATE       // anulada con <48h (se descuenta)
  CANCELLED_MEDICAL    // anulada con justificante médico
  NO_SHOW
}
