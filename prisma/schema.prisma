generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth tables ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Application models ──

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("STUDENT") // STUDENT | TEACHER | ADMIN
  passwordHash  String?
  level         String?   // CEFR: A1, A2, B1, B2, C1, C2
  route         String?   // "preparacion-examen" | "conversacion"
  phone         String?
  active        Boolean   @default(true)
  coachId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Billing / facturación
  billingType        String?
  billingNif         String?
  billingRazonSocial String?
  billingDireccion   String?
  billingCiudad      String?
  billingCP          String?
  billingPais        String?   @default("España")
  billingContacto    String?
  billingEmail       String?

  coach    User?  @relation("CoachStudents", fields: [coachId], references: [id])
  students User[] @relation("CoachStudents")

  accounts Account[]
  sessions Session[]

  studentPacks     Pack[]
  studentLessons   Lesson[]   @relation("StudentLessons")
  studentMaterials Material[] @relation("StudentMaterials")
  studentPayments  Payment[]

  teacherLessons      Lesson[]       @relation("TeacherLessons")
  teacherAvailability Availability[]
  uploadedMaterials   Material[]     @relation("UploadedMaterials")

  invoices            Invoice[]
  facturas            Factura[]  @relation("FacturasAlumno")
  assessmentLinks     AssessmentLink[]
  examAttempts        ExamAttempt[]
  preparateurProfile  PreparateurProfile?
  examenModelos       ExamenModelo[]
  reviews             Review[]

  teacherRecurringSlots RecurringSlot[] @relation("TeacherRecurringSlots")
  studentRecurringSlots RecurringSlot[] @relation("StudentRecurringSlots")

  @@map("users")
}

model Pack {
  id          String   @id @default(cuid())
  studentId   String
  hoursTotal  Float    // e.g. 4.0
  hoursUsed   Float    @default(0)
  price       Float    // e.g. 140.00
  levelRange  String   // "A1-B2" or "C1-C2"
  status      String   @default("ACTIVE") // ACTIVE | EXPIRED | EXHAUSTED | CANCELLED
  purchasedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student  User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Payment[]
  lessons  Lesson[]

  @@map("packs")
}

model Lesson {
  id              String   @id @default(cuid())
  studentId       String
  teacherId       String
  packId          String?
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  zoomLink        String?
  zoomMeetingId   String?
  zoomStartUrl    String?
  status          String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED | NO_SHOW | PENDING_PAYMENT
  focus           String?
  notes           String?
  studentFeedback String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Zoom recording (Phase 1A)
  recordingUrl       String?
  recordingPassword  String?
  recordingReadyAt   DateTime?

  // Zoom attendance tracking (Phase 2)
  teacherJoinedAt    DateTime?
  teacherLeftAt      DateTime?
  studentJoinedAt    DateTime?
  studentLeftAt      DateTime?
  actualDurationMin  Int?
  attendanceSource   String?    // "zoom_webhook" | "manual"

  // Post-class flow (Phase 3)
  postClassEmailSentAt DateTime?

  // Cancellation request
  cancellationRequestedAt DateTime?

  // Modality & recurring
  modality        String  @default("ZOOM") // ZOOM | PRESENCIAL
  recurringSlotId String?

  student       User           @relation("StudentLessons", fields: [studentId], references: [id])
  teacher       User           @relation("TeacherLessons", fields: [teacherId], references: [id])
  recurringSlot RecurringSlot? @relation(fields: [recurringSlotId], references: [id], onDelete: SetNull)
  pack      Pack?      @relation(fields: [packId], references: [id])
  materials Material[]
  review    Review?

  @@index([studentId, scheduledAt])
  @@index([teacherId, scheduledAt])
  @@index([zoomMeetingId])
  @@map("lessons")
}

model Material {
  id           String   @id @default(cuid())
  lessonId     String?
  studentId    String
  uploadedById String
  type         String   // PDF | AUDIO | DOC | NOTE
  title        String
  storagePath  String
  publicUrl    String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson     Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  student    User    @relation("StudentMaterials", fields: [studentId], references: [id])
  uploadedBy User    @relation("UploadedMaterials", fields: [uploadedById], references: [id])

  @@index([studentId])
  @@index([lessonId])
  @@map("materials")
}

model Payment {
  id              String    @id @default(cuid())
  studentId       String
  packId          String?
  amount          Float
  method          String    @default("STRIPE") // STRIPE | TRANSFER | BIZUM | OTHER
  status          String    @default("PENDING") // PENDING | CONFIRMED | REJECTED | REFUNDED
  reference       String?
  stripeSessionId String?   @unique
  stripePaymentId String?
  notes           String?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  pack    Pack?    @relation(fields: [packId], references: [id])
  invoice Invoice?

  @@index([studentId])
  @@map("payments")
}

model Invoice {
  id           String   @id @default(cuid())
  number       String   @unique // HB-2026-0001
  paymentId    String   @unique
  studentId    String
  studentName  String
  studentEmail String
  concept      String
  baseAmount   Float
  ivaRate      Float    @default(21)
  ivaAmount    Float
  totalAmount  Float
  storagePath  String?
  issuedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  student User    @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("invoices")
}

model Availability {
  id        String  @id @default(cuid())
  teacherId String
  dayOfWeek Int     // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String  // "09:00"
  endTime   String  // "10:00"
  active    Boolean @default(true)

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, dayOfWeek, startTime])
  @@map("availability")
}

model AssessmentLink {
  id           String   @id @default(cuid())
  userId       String
  attemptId    String   @unique
  assessmentId String
  linkedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assessment_links")
}

// ── Le Marché (weekly quiz) ──

model Quiz {
  id          String    @id @default(cuid())
  weekNumber  Int
  year        Int
  theme       String
  title       String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  questions QuizQuestion[]
  results   QuizResult[]

  @@unique([weekNumber, year])
  @@map("quizzes")
}

model QuizQuestion {
  id          String  @id @default(cuid())
  quizId      String
  text        String
  textFr      String?
  options     String  // JSON string: ["option1","option2","option3","option4"]
  correctIdx  Int
  explanation String?
  imageUrl    String?
  order       Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizResult {
  id        String   @id @default(cuid())
  quizId    String
  name      String
  email     String
  score     Int
  timeMs    Int
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, score])
  @@map("quiz_results")
}

// ── Newsletter ──

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)

  @@map("newsletter_subscribers")
}

// ── Assessment Attempts ──

model AssessmentAttempt {
  id            String   @id @default(cuid())
  assessmentId  String
  attemptToken  String   @unique @default(cuid())
  candidateId   String
  status        String   @default("IN_PROGRESS") // IN_PROGRESS | FINISHED
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  result        String?  // JSON string of AssessmentResult
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  answers AssessmentAttemptAnswer[]

  @@index([assessmentId])
  @@index([candidateId])
  @@map("assessment_attempts")
}

model AssessmentAttemptAnswer {
  id               String   @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean
  pointsAwarded    Float    @default(0)
  clientSequence   Int?
  answeredAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("assessment_attempt_answers")
}

// ── AI Writing Correction ──

model WritingCorrection {
  id              String   @id @default(cuid())
  userId          String?
  candidateEmail  String
  level           String   // CEFR: A1, A2, B1, B2, C1, C2
  taskType        String   // e.g. "lettre_formelle", "essai", "carte_postale"
  taskPrompt      String?
  inputText       String
  wordCount       Int
  globalScore     Float?
  maxScore        Float?
  criterionScores String?  // JSON: { criterion: { score, max, comment } }
  annotations     String?  // JSON: [{ start, end, type, original, correction, explanation }]
  correctedText   String?
  overallFeedback String?
  estimatedLevel  String?
  nextSteps       String?  // JSON: string[]
  modelUsed       String?
  inputTokens     Int?
  outputTokens    Int?
  latencyMs       Int?
  status          String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | ERROR
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attemptId       String?

  teacherAnnotations TeacherAnnotation[]
  examAttempt        ExamAttempt?         @relation(fields: [attemptId], references: [id])

  @@index([candidateEmail])
  @@index([userId, status])
  @@index([attemptId])
  @@map("writing_corrections")
}

model CorrectionQuota {
  id            String   @id @default(cuid())
  email         String   @unique
  freeUsed      Int      @default(0)
  freeLimit     Int      @default(3)
  paidRemaining Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("correction_quotas")
}

model TeacherAnnotation {
  id             String   @id @default(cuid())
  correctionId   String
  teacherId      String
  content        String
  scoreOverride  String?  // JSON: { criterion: newScore }
  createdAt      DateTime @default(now())

  correction WritingCorrection @relation(fields: [correctionId], references: [id], onDelete: Cascade)

  @@map("teacher_annotations")
}

// ── Exam Calendar ──

model ExamSession {
  id                   String    @id @default(cuid())
  examType             String    // "DELF" | "DALF" | "EOI"
  level                String    // CEFR level
  center               String
  centerType           String    // "ALLIANCE_FRANCAISE" | "INSTITUT_FRANCAIS" | "EOI"
  city                 String
  province             String
  autonomousCommunity  String
  registrationStart    DateTime?
  registrationEnd      DateTime?
  writtenExamDate      DateTime?
  oralExamStart        DateTime?
  oralExamEnd          DateTime?
  resultsDate          DateTime?
  fee                  Float?
  sourceUrl            String?
  notes                String?
  verified             Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  reminders ExamReminder[]

  @@index([examType, level])
  @@index([autonomousCommunity])
  @@map("exam_sessions")
}

model ExamReminder {
  id            String    @id @default(cuid())
  userId        String
  examSessionId String
  reminderType  String    // "REGISTRATION_OPEN" | "REGISTRATION_CLOSING" | "EXAM_WEEK"
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, examSessionId, reminderType])
  @@map("exam_reminders")
}

// ── Exam Simulation Attempts ──

model ExamAttempt {
  id          String    @id @default(cuid())
  userId      String
  examenId    String    // e.g. 'A2-exemple1'
  nivel       String    // CEFR: A1, A2, B1, B2, C1, C2
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  scoreCO     Float?
  scoreCE     Float?
  scorePE     Float?
  scorePO     Float?
  totalScore  Float?
  passed      Boolean?
  status         String    @default("in_progress") // in_progress | finished
  answers        String?   // JSON: RespuestaCandidat[] serialized
  aiAnalysis     String?   // JSON: AI analysis result
  aiAnalyzedAt   DateTime?
  followupSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  corrections WritingCorrection[]

  @@index([userId])
  @@index([examenId])
  @@map("exam_attempts")
}

// ── Marketplace Préparateurs ──

model PreparateurProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  slug                  String   @unique
  displayName           String
  bio                   String
  photo                 String?
  languages             String[]
  specialties           String[]
  levels                String[]
  hourlyRate            Int      // cents: 3500 = 35.00 €
  feiCertification      String?
  certificationVerified Boolean  @default(false)
  verifiedBy            String?
  verifiedAt            DateTime?
  status                String   @default("PENDING") // PENDING | ACTIVE | SUSPENDED
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionStatus    String?
  totalClasses          Int      @default(0)
  avgRating             Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  reviews PreparateurReview[]

  @@map("preparateur_profiles")
}

model PreparateurReview {
  id            String   @id @default(cuid())
  preparateurId String
  studentId     String
  lessonId      String   @unique
  rating        Int      // 1-5
  comment       String?
  source        String   @default("platform") // "platform" | "google"
  createdAt     DateTime @default(now())

  preparateur PreparateurProfile @relation(fields: [preparateurId], references: [id])

  @@index([preparateurId])
  @@map("preparateur_reviews")
}

// ── Exam Builder ──

model ExamenModelo {
  id         String   @id @default(cuid())
  titulo     String
  nivel      String   // A2|B1|B2|C1|C2
  diploma    String   // DELF|DALF
  numero     Int
  status     String   @default("DRAFT") // DRAFT|REVIEW|PUBLISHED
  esPago     Boolean  @default(true)
  precio     Int?     // céntimos, null = gratis
  creadoPor  String
  profesor   User     @relation(fields: [creadoPor], references: [id])
  secciones  Json     // SeccionExamen[] completa
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([creadoPor])
  @@index([nivel, status])
  @@map("examen_modelos")
}

// ── Reviews (post-clase) ──

model Review {
  id          String    @id @default(cuid())
  lessonId    String    @unique
  studentId   String
  studentName String?
  rating      Int?      // 1-5
  comment     String?
  token       String    @unique @default(cuid())
  createdAt   DateTime  @default(now())
  submittedAt DateTime?

  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("reviews")
}

model StripeEvent {
  id        String   @id // Stripe event.id (evt_...)
  createdAt DateTime @default(now())

  @@map("stripe_events")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  objetivo  String?
  message   String?
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("leads")
}

model ZoomEvent {
  id        String   @id
  type      String
  meetingId String
  payload   String?
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@map("zoom_events")
}

model PreparateurApplication {
  id         String   @id @default(cuid())
  name       String
  email      String
  levels     String[]
  experience Int
  hourlyRate Int
  message    String?
  cvUrl      String?
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt  DateTime @default(now())

  @@map("preparateur_applications")
}

// ── Facturas formales ──

model Factura {
  id                     String    @id @default(cuid())
  numero                 String    @unique
  serie                  String    @default("HB")
  anio                   Int
  secuencial             Int
  pagoId                 String?
  alumnoId               String
  clienteNombre          String
  clienteNif             String?
  clienteRazonSocial     String?
  clienteDireccion       String?
  clienteEmail           String?
  concepto               String
  baseImponible          Float
  tipoIva                Float     @default(21)
  cuotaIva               Float
  total                  Float
  formaPago              String?
  estado                 String    @default("emitida") // emitida | anulada
  facturaRectificativaId String?
  fechaEmision           DateTime  @default(now())
  fechaAnulacion         DateTime?
  motivoAnulacion        String?
  pdfPath                String?
  createdAt              DateTime  @default(now())

  alumno User @relation("FacturasAlumno", fields: [alumnoId], references: [id])

  @@index([alumnoId])
  @@index([anio, serie])
  @@map("facturas")
}

// ── Recurring Slots (horarios reservados) ──

model RecurringSlot {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  dayOfWeek Int      // 0=Sun..6=Sat
  startTime String   // "09:00"
  modality  String   @default("ZOOM") // ZOOM | PRESENCIAL
  active    Boolean  @default(true)
  notes     String?  // ej: "Oficina C/Larios"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher User     @relation("TeacherRecurringSlots", fields: [teacherId], references: [id], onDelete: Cascade)
  student User     @relation("StudentRecurringSlots", fields: [studentId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([teacherId, dayOfWeek, startTime])
  @@index([studentId])
  @@map("recurring_slots")
}
